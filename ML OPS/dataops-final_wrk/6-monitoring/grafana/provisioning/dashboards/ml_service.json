{
  "title": "ML Service Dashboard",
  "uid": "ml-service",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ml_service_requests_total)",
          "legendFormat": "Total",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ml_service_requests_total{status='error'}) / sum(ml_service_requests_total) * 100",
          "legendFormat": "Error %",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests per second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ml_service_requests_total[1m])",
          "legendFormat": "{{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Latency (seconds)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ml_service_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.50, rate(ml_service_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
